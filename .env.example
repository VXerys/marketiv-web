# OpenRouter API Configuration (FREE - no credit card needed)
# Sign up at https://openrouter.ai/ (Google/GitHub login)
# Get your free API key at https://openrouter.ai/settings/keys

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3.5-35b-a3b

# ---------------------------------------------------------------------------
# Appwrite — Public (Browser-Safe) Variables
# These are safe to expose to the browser via NEXT_PUBLIC_ prefix.
# Do NOT add API keys or server-only credentials here.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APPWRITE_ENDPOINT=
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_DATABASE_ID=
NEXT_PUBLIC_APPWRITE_STORAGE_BUCKET_ID=

# ---------------------------------------------------------------------------
# Appwrite — Server-Only Variables (NEVER expose to browser)
# Used only in Appwrite Functions or secure Server Actions.
# ---------------------------------------------------------------------------
# APPWRITE_API_KEY=           # Server SDK elevated key — server only
